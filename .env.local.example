# Vercel Environment Variables
# These should be set in Vercel Dashboard: Settings → Environment Variables

# サイトの正式URL（SEO: metadataBase / sitemap / robots / canonical / JSON-LD に使用）
# 正式ドメイン確定後に必ず設定してください（例: https://www.kanae-tokyo.com）
NEXT_PUBLIC_SITE_URL=https://kanae-tau.vercel.app

# Supabase（問い合わせ・物件データ用）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # サーバー専用（管理系API）。クライアントに出さないこと

# 管理系API認証キー（/api/crm/*, /api/inquiries, /api/properties の POST/PUT/DELETE）
# ランダムな長い文字列を設定（例: openssl rand -hex 32）
# 呼び出し側は Authorization: Bearer <key> ヘッダを付けること
ADMIN_API_KEY=change-me-to-a-long-random-string

# 問い合わせ通知メール（Resend）
RESEND_API_KEY=re_xxxxxxxx

# Local development only
NODE_ENV=development
